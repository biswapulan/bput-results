# Copy this file to .env.local for local development.
# In production (Vercel), set these under Project Settings → Environment Variables.

# Auto-filled when you connect the Upstash-for-Redis integration from the
# Vercel Marketplace (Storage tab → Browse Storage → Upstash → Upstash for Redis).
# Depending on how the integration names things, you may see either pair —
# the code checks both, so whichever one Vercel created for you is fine.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# or, if your integration used the newer naming instead:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Random long secret used to sign login session cookies.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Secret only you know — required to call /api/admin/create-user and
# create a new CR/faculty account. Generate the same way as above.
ADMIN_SECRET=
