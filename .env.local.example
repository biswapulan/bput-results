# Copy this file to .env.local for local development.
# In production (Vercel), set these under Project Settings → Environment Variables.

# Auto-filled when you add an Upstash Redis integration from the Vercel
# Marketplace (Storage tab → Browse Marketplace → Redis → Upstash).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Random long secret used to sign login session cookies.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Secret only you know — required to call /api/admin/create-user and
# create a new CR/faculty account. Generate the same way as above.
ADMIN_SECRET=
